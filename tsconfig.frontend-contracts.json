{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": false,
    "lib": ["ES2020", "DOM"]
  },
  "include": [
    "assets/js/ai-orchestration.js",
    "assets/js/ai-prompt-builder.js",
    "assets/js/ai-response-handler.js",
    "assets/js/ai-chat-controller.js",
    "assets/js/settings-sections-runtime.js",
    "assets/js/settings-detail-runtime.js",
    "assets/js/settings-modal-runtime.js",
    "assets/js/settings-actions-runtime.js",
    "assets/js/settings-render-runtime.js",
    "assets/js/settings-controller-runtime.js",
    "interfaces/**/*.d.ts"
  ]
}
